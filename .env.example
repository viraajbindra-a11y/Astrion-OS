# Astrion OS — environment variables
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.
#
# Usage: `npm run dev:keyed` will load this file before starting the server.

# Anthropic API key — required for real-Claude soak testing (Phase 0)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the default model
# Default is claude-haiku-4-5-20251001
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
